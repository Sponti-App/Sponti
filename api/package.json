{
  "name": "sponti-api-server",
  "version": "1.0.0",
  "description": "Main business API server for Sponti.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --conditions=development src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "imports": {
    "#app": {
      "development": "./src/app.ts",
      "default": "./dist/app.js"
    },
    "#config/*": {
      "development": "./src/config/*.ts",
      "default": "./dist/config/*.js"
    },
    "#controllers/*": {
      "development": "./src/controllers/*.ts",
      "default": "./dist/controllers/*.js"
    },
    "#db/*": {
      "development": "./src/db/*.ts",
      "default": "./dist/db/*.js"
    },
    "#middleware/*": {
      "development": "./src/middleware/*.ts",
      "default": "./dist/middleware/*.js"
    },
    "#models/*": {
      "development": "./src/models/*.ts",
      "default": "./dist/models/*.js"
    },
    "#routes/*": {
      "development": "./src/routes/*.ts",
      "default": "./dist/routes/*.js"
    },
    "#schemas/*": {
      "development": "./src/schemas/*.ts",
      "default": "./dist/schemas/*.js"
    },
    "#services/*": {
      "development": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "#utils/*": {
      "development": "./src/utils/*.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "morgan": "^1.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.15"
  }
}
