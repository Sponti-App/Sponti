# Copy to .env.local and fill in. .env.local is gitignored.

# Google Places proxy (server-only) and Maps JS (browser-restricted).
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_ID=

# Google Identity Services OAuth client ID for the web app.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# auth-server.
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000

# main api server.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
