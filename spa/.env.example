# Copy to .env.local and fill in. .env.local is gitignored.

# Google Maps — domain-restrict the key in GCP console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_ID=

# auth-server. Default 3001 because Next dev server uses 3000.
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3001

# main api server (built in Stage 4).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002
